# Core app configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=replace-with-a-long-random-secret-at-least-20-characters
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Email delivery
EMAIL_USER=support@prophives.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM=support@prophives.com

# Internal automation auth
INTERNAL_AUTOMATION_KEY=replace-with-long-random-secret

# Optional SMTP overrides
# Leave SMTP_HOST empty to use the default Nodemailer service transport.
# Set all three values below if you are using a custom SMTP host.
SMTP_HOST=
# SMTP_PORT=465
# SMTP_SECURE=true

# Optional runtime overrides with code defaults
# PORT=8787
# NODE_ENV=development
# PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Optional AI provider
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional Telegram integration
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ONBOARDING_TOKEN_TTL_MINUTES=30


# WhatsApp Cloud API integration
# Set to 'meta' to enable real WhatsApp Cloud API integration
WHATSAPP_PROVIDER=meta
# Your Meta WhatsApp Cloud API access token
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
# Your WhatsApp Business phone number ID
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
# Webhook verification token (used for webhook setup)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-verify-token
# Webhook secret (optional, for extra security)
WHATSAPP_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Production examples
# FRONTEND_URL=https://your-frontend-project.vercel.app
# ALLOWED_ORIGINS=https://your-frontend-project.vercel.app
# EMAIL_USER=support@prophives.com
# EMAIL_PASS=your-production-mail-password
# EMAIL_FROM=support@prophives.com
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_SECURE=true
